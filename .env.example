# Copy this file to .env and fill in values for local development.
# .env is gitignored.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── JWT (Phase 2) ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── RabbitMQ (Phase 4) ────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Grafana (Phase 7) ─────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
